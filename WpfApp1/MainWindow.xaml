<Window x:Class="AppointmentPlanner.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meeting Room Scheduler"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Room:" Margin="0,0,10,0"/>
            <ComboBox x:Name="RoomComboBox" Width="200" Margin="0,0,20,0"/>
            <TextBlock Text="Day:" Margin="0,0,10,0"/>
            <DatePicker x:Name="DayPicker" Width="150"/>
        </StackPanel>

        <ListBox x:Name="appointmentsListBox"
                 Grid.Row="1"
                 Margin="0,0,0,10"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Grid.Row="2">
            <Button Content="Add Appointment"
                    Width="150"
                    Margin="0,0,10,0"/>
            <Button Content="Cancel Appointment"
                    Width="150"
                    Margin="0,0,10,0"/>
            <Button Content="Refresh"
                    Width="150"/>
        </StackPanel>

    </Grid>
</Window>